generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  age        Int

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  posts      Post[]
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userId     Int
  user       User      @relation(fields: [userId], references: [id])
}